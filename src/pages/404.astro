---
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout title="Seite nicht gefunden" description="Diese Seite wurde nicht gefunden.">
  <section class="page-head compact" aria-labelledby="not-found-title">
    <p class="eyebrow">404</p>
    <h1 id="not-found-title">Seite nicht gefunden</h1>
    <p>Die gesuchte Adresse existiert nicht oder wurde an einen anderen Ort im Archiv verschoben.</p>
    <p><a class="button button--primary" href="/">Zur Startseite</a></p>
  </section>
</BaseLayout>
