---
import BaseLayout from "../../layouts/BaseLayout.astro";
import {
  formatDate,
  getAlbumUrl,
  getArchivedAlbums,
  groupArchivedAlbumsByYear,
} from "@lib/albums";

const archivedAlbums = await getArchivedAlbums();
const groups = groupArchivedAlbumsByYear(archivedAlbums);
---

<BaseLayout title="Archiv" description="Archivierte analoge Fotoalben.">
  <section class="page-head" aria-labelledby="archive-title">
    <p class="eyebrow">Archiv</p>
    <h1 id="archive-title">Archivierte Alben</h1>
    <p>
      Ältere Serien bleiben erhalten, geordnet nach Jahr und weiterhin über
      ihre direkten URLs erreichbar.
    </p>
  </section>

  {
    groups.length > 0 ? (
      <div class="archive-list">
        {groups.map(([year, albums]) => (
          <section class="archive-year" aria-labelledby={`year-${year}`}>
            <h2 id={`year-${year}`}>{year}</h2>
            <ol>
              {albums.map((album) => (
                <li>
                  <a href={getAlbumUrl(album)}>{album.data.title}</a>
                  <time datetime={album.data.date.toISOString()}>
                    {formatDate(album.data.date)}
                  </time>
                </li>
              ))}
            </ol>
          </section>
        ))}
      </div>
    ) : (
      <section class="empty-state empty-state--archive" aria-labelledby="archive-empty-title">
        <div class="empty-state__copy">
          <p class="eyebrow">Magazin</p>
          <h2 id="archive-empty-title">Kein Archivinhalt</h2>
          <p>Archivierte Alben erscheinen hier, sobald ältere Serien aus der Startansicht wandern.</p>
        </div>
        <div class="archive-spool" aria-hidden="true">
          <span></span>
          <span></span>
          <span></span>
        </div>
      </section>
    )
  }
</BaseLayout>
